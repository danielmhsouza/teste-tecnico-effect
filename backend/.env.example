# ──────────────────────────────────────────────────────────────────────────────
# CrescentPHP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# NUNCA versione o .env real!
# ──────────────────────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME=CrescentApp
APP_ENV=development          # development | production
APP_SECRET=troque_isso_por_uma_string_longa_e_aleatoria_32chars
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_DRIVER=mysql              # mysql | pgsql | sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=meu_banco
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SQLite (alternativa sem servidor — ótimo para hospedagem barata)
# DB_DRIVER=sqlite
# DB_NAME=/caminho/para/banco.sqlite

# ── E-mail (opcional) ─────────────────────────────────────────────────────────
MAIL_DRIVER=smtp             # smtp | mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu@email.com
MAIL_PASS=
MAIL_FROM=noreply@meusite.com.br
MAIL_FROM_NAME="Meu App"
